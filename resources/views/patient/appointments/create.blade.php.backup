@push('scripts')
<script>
function appointmentForm() {
    return {
        step: 1,
        department: '',
        selectedDoctor: '',
        selectedDoctorName: '',
        appointmentDate: '',
        appointmentTime: '',

        nextStep() {
            if (this.step < 3) {
                this.step++;
            }
        },

        prevStep() {
            if (this.step > 1) {
                this.step--;
            }
        },

        updateDoctorName(doctorId, doctorName) {
            this.selectedDoctor = doctorId;
            this.selectedDoctorName = doctorName;
        },

        filterDoctors() {
            const options = document.querySelectorAll('.doctor-option');
            options.forEach(option => {
                if (!this.department || option.dataset.department === this.department) {
                    option.style.display = 'block';
                } else {
                    option.style.display = 'none';
                }
            });
        },

        formatDateTime() {
            if (!this.appointmentDate || !this.appointmentTime) return 'Not selected';
            const date = new Date(this.appointmentDate + ' ' + this.appointmentTime);
            return date.toLocaleDateString() + ' at ' + date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        }
    }
}
</script>
@endpush
